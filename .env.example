# Database (Supabase / Neon / Railway — must be a hosted Postgres instance)
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true&connection_limit=1"

# Redis (Upstash Redis URL works perfectly)
REDIS_URL="rediss://default:password@host.upstash.io:6379"

# Base URL (used for server-to-server API calls during SSR)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron job secret — set to a random string, add same value to Vercel env
CRON_SECRET="your-secret-here"
